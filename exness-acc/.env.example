# Security API Key for authentication between your main VPS (web/bot) and this service VPS
API_KEY=your_super_secure_api_key_here

# Encryption Key for securing user MT5 passwords in database. 
# Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# Database settings
DATABASE_URL=sqlite:///./exness_service.db

# MT5 Connection Settings
# Set to True for testing on Linux/Mac without real MT5 installed
MT5_MOCK_MODE=True

# Path to the MT5 terminal executable (only used if MT5_MOCK_MODE=False)
# Example Windows: C:/Program Files/MetaTrader 5 Exness/terminal64.exe
# Example Linux (Wine): /home/ubuntu/.wine/drive_c/Program Files/MetaTrader 5/terminal64.exe
MT5_TERMINAL_PATH=
